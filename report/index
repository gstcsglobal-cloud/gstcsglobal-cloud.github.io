const valLabelPlugin={id:'valLabel',
  afterDatasetsDraw(chart,args,o){
    if(!o||!o.mode)return;
    const meta=chart.getDatasetMeta(0), ds=chart.data.datasets[0], ctx=chart.ctx;
    if(!meta||!meta.data||!meta.data.length)return;
    const nums=ds.data.filter(v=>v!=null&&isFinite(v));
    const max=nums.length?Math.max.apply(null,nums):null;
    ctx.save();ctx.fillStyle=o.color||'#E6EDF3';
    ctx.font='700 11px "Segoe UI","Malgun Gothic",sans-serif';
    meta.data.forEach(function(el,i){
      const v=ds.data[i]; if(v==null)return;
      if(o.mode==='peaks'){
        const fm=ds.data.findIndex(x=>x===max);
        if(!((i===fm&&v>0)||(i===ds.data.length-1&&v>0)))return;
      }
      ctx.textAlign='center';ctx.textBaseline='bottom';
      ctx.fillText((+v).toLocaleString(),el.x,el.y-6);
    });
    ctx.restore();
  }};
function inkStrong(TH){return TH.key==='light'?'#0f172a':'#E6EDF3';}
