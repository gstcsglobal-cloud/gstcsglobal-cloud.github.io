const MS=86400000;
function pd(s){ // '2022. 8. 1' / '2025-07-10' / Date
  if(!s)return null; s=String(s).trim(); if(!s)return null;
  s=s.replace(/\.\s*/g,'-').replace(/\/-?/g,'-').replace(/-$/,'').replace(/\s/g,'');
  const m=s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
  if(!m)return null;
  const d=new Date(Date.UTC(+m[1],+m[2]-1,+m[3]));
  return isNaN(d)?null:d;
}
function fmtYM(d){return d.getUTCFullYear()+'-'+String(d.getUTCMonth()+1).padStart(2,'0');}
function isoW(d){
  const x=new Date(Date.UTC(d.getUTCFullYear(),d.getUTCMonth(),d.getUTCDate()));
  const dow=(x.getUTCDay()+6)%7; x.setUTCDate(x.getUTCDate()-dow+3);
  const fy=new Date(Date.UTC(x.getUTCFullYear(),0,4));
  const w=1+Math.round(((x-fy)/MS-3+((fy.getUTCDay()+6)%7))/7);
  return x.getUTCFullYear()+'-W'+String(w).padStart(2,'0');
}
function keyOfDate(d){return PERIOD==='w'?isoW(d):fmtYM(d);}
function periods(n){
  const out=[]; const today=new Date(); today.setUTCHours(0,0,0,0);
  if(PERIOD==='w'){
    const mon=new Date(today); mon.setUTCDate(mon.getUTCDate()-((mon.getUTCDay()+6)%7));
    for(let i=n-1;i>=0;i--){
      const st=new Date(mon.getTime()-i*7*MS), en=new Date(st.getTime()+6*MS);
      const k=isoW(st);
      out.push({key:k,label:'W'+k.slice(-2),end:en>today?today:en});
    }
  }else{
    for(let i=n-1;i>=0;i--){
      let y=today.getUTCFullYear(), m=today.getUTCMonth()-i; while(m<0){m+=12;y--;}
      const en=new Date(Date.UTC(y,m+1,0));
      out.push({key:y+'-'+String(m+1).padStart(2,'0'),label:(m+1)+t('mon_u'),end:en>today?today:en});
    }
  }
  return out;
}
function setPeriod(p){PERIOD=p;try{localStorage.setItem('gst_rpt_period',p);}catch(e){}
  document.getElementById('ptW').classList.toggle('active',p==='w');
