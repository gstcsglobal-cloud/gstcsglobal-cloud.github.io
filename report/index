// ===== HR 파싱 (헤더 기반) =====
function parseHR(rows){
  const hdr=(rows[0]||[]).map(x=>String(x).trim().toLowerCase());
  const idx=n=>hdr.findIndex(h=>n.includes(h)&&h);
  const col={
    name:hdr.findIndex(h=>['name','이름','성명'].includes(h)),
    join:hdr.findIndex(h=>['join','입사일'].includes(h)),
    basic:hdr.findIndex(h=>['basic','basic교육'].includes(h)),
    vet:hdr.findIndex(h=>['vet','veteran','veteran교육'].includes(h)),
    bdate:hdr.findIndex(h=>h.replace(/\s/g,'')==='basic이수일'),
    vdate:hdr.findIndex(h=>h.replace(/\s/g,'')==='vet이수일'||h.replace(/\s/g,'')==='veteran이수일'),
    quit:hdr.findIndex(h=>['퇴사일','quit','leave'].includes(h))
  };
  return rows.slice(1).map(r=>({
    name:col.name>=0?String(r[col.name]||'').trim():'',
    join:col.join>=0?pd(r[col.join]):null,
    basic:col.basic>=0?String(r[col.basic]||'').trim():'',
    vet:col.vet>=0?String(r[col.vet]||'').trim():'',
    bdate:col.bdate>=0?pd(r[col.bdate]):null,
    vdate:col.vdate>=0?pd(r[col.vdate]):null,
    quit:col.quit>=0?pd(r[col.quit]):null
  })).filter(x=>x.name);
}
function activeAt(p,E){return p.join&&p.join<=E&&(!p.quit||p.quit>E);}

