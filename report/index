      const bD=bT.filter(x=>x.bdate&&x.bdate<=p.end).length;
      const vD=vT.filter(x=>x.vdate&&x.vdate<=p.end).length;
      bR.push(bT.length?Math.round(bD/bT.length*100):null);
      vR.push(vT.length?Math.round(vD/vT.length*100):null);
    });
    destroyMk('cEdu');
    CHARTS.cEdu=new Chart(document.getElementById('cEdu'),{type:'line',
      data:{labels,datasets:[
        {label:'Basic',data:bR,borderColor:TH.pal[0],backgroundColor:TH.pal[0],pointRadius:2.5,tension:.3},
        {label:'Veteran',data:vR,borderColor:TH.pal[3],backgroundColor:TH.pal[3],pointRadius:2.5,tension:.3}]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:'bottom',labels:{color:TH.txt,font:{size:10},usePointStyle:true,pointStyle:'circle',boxWidth:6,padding:8}},
          tooltip:{callbacks:{label:c=>' '+c.dataset.label+' '+c.parsed.y+'%'}}},
        scales:{x:{ticks:{color:TH.txt,font:{size:10},maxRotation:0,autoSkip:true,maxTicksLimit:12},grid:{display:false}},
                y:{min:0,max:100,ticks:{color:TH.txt,callback:v=>v+'%',maxTicksLimit:5},grid:{color:TH.grid}}}}});
  }

  // ===== 작업 실행력 =====
  const d30=new Date(today.getTime()-30*MS), d60=new Date(today.getTime()-60*MS);
  const j30=WK.filter(x=>x.wd>=d30).length, jPrev=WK.filter(x=>x.wd>=d60&&x.wd<d30).length;
  const man30=WK.filter(x=>x.wd>=d30).reduce((a,x)=>a+x.manMin,0);
  const manPM30=WK.filter(x=>x.wd>=d30&&isPM(x.stage)).reduce((a,x)=>a+x.manMin,0);
  setTxt('kp4',j30.toLocaleString()); setTxt('kd4',GST.deltaBadge(j30,jPrev,true));
  setTxt('kf4',t('kf4').replace('{n}',jPrev.toLocaleString()));
  setTxt('kp5',Math.round(man30/60).toLocaleString());
  setTxt('kf5',t('kf5').replace('{p}',man30?Math.round(manPM30/man30*100):0));
  {
    const jc=P.map(p=>WK.filter(x=>keyOfDate(x.wd)===p.key).length);
    destroyMk('cJobs');
    CHARTS.cJobs=new Chart(document.getElementById('cJobs'),{type:'bar',
      data:{labels,datasets:[{data:jc,backgroundColor:TH.pal[0],borderRadius:4}]},
      options:{responsive:true,maintainAspectRatio:false,layout:{padding:{top:16}},
        plugins:{legend:{display:false},valLabel:{mode:'peaks',color:ink}},
        scales:baseScales(TH,false)},
      plugins:[valLabelPlugin]});
  }
  {
    const hPM=P.map(p=>Math.round(WK.filter(x=>keyOfDate(x.wd)===p.key&&isPM(x.stage)).reduce((a,x)=>a+x.manMin,0)/60));
    const hSv=P.map(p=>Math.round(WK.filter(x=>keyOfDate(x.wd)===p.key&&isSvc(x.stage)).reduce((a,x)=>a+x.manMin,0)/60));
    const hIn=P.map(p=>Math.round(WK.filter(x=>keyOfDate(x.wd)===p.key&&isInst(x.stage)).reduce((a,x)=>a+x.manMin,0)/60));
    destroyMk('cMan');
    CHARTS.cMan=new Chart(document.getElementById('cMan'),{type:'bar',
      data:{labels,datasets:[
        {label:t('man_pm'),data:hPM,backgroundColor:TH.pal[0],stack:'s',borderRadius:2},
        {label:t('man_svc'),data:hSv,backgroundColor:TH.status.bad,stack:'s',borderRadius:2},
        {label:t('man_inst'),data:hIn,backgroundColor:TH.pal[2],stack:'s',borderRadius:2}]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:'bottom',labels:{color:TH.txt,font:{size:10},usePointStyle:true,pointStyle:'circle',boxWidth:6,padding:8}},
          tooltip:{callbacks:{footer:it=>'Σ '+it.reduce((a,i)=>a+i.parsed.y,0).toLocaleString()+'h'}}},
        scales:baseScales(TH,true)}});
  }
  {
    const pc=P.map(p=>{
      const rows=WK.filter(x=>keyOfDate(x.wd)===p.key);
      const ppl=new Set(); rows.forEach(x=>x.workers.forEach(w=>ppl.add(w)));
      return ppl.size?Math.round(rows.length/ppl.size*10)/10:0;
    });
    destroyMk('cPc');
    CHARTS.cPc=new Chart(document.getElementById('cPc'),{type:'bar',
      data:{labels,datasets:[{data:pc,backgroundColor:TH.pal[3],borderRadius:4}]},
      options:{responsive:true,maintainAspectRatio:false,layout:{padding:{top:16}},
        plugins:{legend:{display:false},valLabel:{mode:'peaks',color:ink},
          tooltip:{callbacks:{label:c=>{
            const rows=WK.filter(x=>keyOfDate(x.wd)===P[c.dataIndex].key);
            const ppl=new Set(); rows.forEach(x=>x.workers.forEach(w=>ppl.add(w)));
            return ' '+c.parsed.y+' ('+rows.length+t('u_c')+' / '+ppl.size+t('u_p')+')';}}}},
        scales:{x:baseScales(TH,false).x,
                y:{ticks:{color:TH.txt,maxTicksLimit:5},grid:{color:TH.grid}}}},
      plugins:[valLabelPlugin]});
  }

  // ===== PM S-커브 (올해, 월 고정) =====
  let scPlan=0, scDone=0;
  {
    const tbm=WK.filter(x=>isPM(x.stage)&&x.sn);
    const g={};
    tbm.forEach(x=>{
      const k=x.sn+'||'+(x.chamber||'-');
      (g[k]=g[k]||[]).push(x.wd);
    });
    const allCy=[];
    Object.values(g).forEach(ds=>{
      ds.sort((a,b)=>a-b); const iv=[];
      for(let i=1;i<ds.length;i++){const dd=(ds[i]-ds[i-1])/MS; if(dd>=7)iv.push(dd);}
      if(iv.length){iv.sort((a,b)=>a-b); ds._cy=Math.round(iv[Math.floor(iv.length/2)]); allCy.push(ds._cy);}
    });
    allCy.sort((a,b)=>a-b);
    const fleet=allCy.length?allCy[Math.floor(allCy.length/2)]:90;
    const y0=new Date(Date.UTC(nowY,0,1));
    const planM=Array(nowM+1).fill(0), doneM=Array(nowM+1).fill(0);
    Object.values(g).forEach(ds=>{
      ds.forEach(d=>{if(d>=y0&&d<=today)doneM[d.getUTCMonth()]++;});
      // 주기를 도출할 수 없는 챔버(TBM 간격 1회 이하)는 계획=실적으로 중립 처리
      if(!ds._cy){
        ds.forEach(d=>{if(d>=y0&&d<=today)planM[d.getUTCMonth()]++;});
        return;
      }
      const cy=ds._cy;
      // 앵커: 올해 이전 마지막 TBM, 없으면 올해 첫 TBM
      let anchor=null;
      ds.forEach(d=>{if(d<y0&&(!anchor||d>anchor))anchor=d;});
      let first=null;
      if(!anchor){ first=ds.find(d=>d>=y0)||null; anchor=first; }
      if(!anchor)return;
      // 올해 첫 TBM을 앵커로 쓴 경우 그 1건도 계획에 포함 (완료와 짝 맞춤)
      if(first&&first<=today)planM[first.getUTCMonth()]++;
      for(let d=new Date(anchor.getTime()+cy*MS); d<=today; d=new Date(d.getTime()+cy*MS)){
        if(d>=y0)planM[d.getUTCMonth()]++;
      }
    });
    let pc=0,dc=0;
    const planC=planM.map(v=>pc+=v), doneC=doneM.map(v=>dc+=v);
    scPlan=pc; scDone=dc;
    const scLabels=planC.map((_,i)=>(i+1)+t('mon_u'));
    const prog=pc?Math.round(dc/pc*100):0;
    setTxt('kp6',prog+'%');
    setTxt('kf6',t('kf6').replace('{a}',pc.toLocaleString()).replace('{b}',dc.toLocaleString()));
    destroyMk('cSc');
    CHARTS.cSc=new Chart(document.getElementById('cSc'),{type:'line',
      data:{labels:scLabels,datasets:[
        {label:t('sc_plan'),data:planC,borderColor:TH.txt,borderDash:[6,4],pointRadius:0,tension:.2,backgroundColor:'transparent'},
        {label:t('sc_done'),data:doneC,borderColor:TH.pal[0],backgroundColor:TH.pal[0]+'33',fill:true,pointRadius:2.5,tension:.2}]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:'bottom',labels:{color:TH.txt,font:{size:10},usePointStyle:true,pointStyle:'circle',boxWidth:6,padding:8}},
          tooltip:{callbacks:{footer:it=>{
            const i=it[0].dataIndex;
            return planC[i]?((doneC[i]/planC[i]*100).toFixed(0)+'%'):'';}}}},
        scales:{x:{ticks:{color:TH.txt,font:{size:10},maxRotation:0},grid:{display:false}},
                y:{ticks:{color:TH.txt,precision:0,maxTicksLimit:5},grid:{color:TH.grid}}}}});
  }

  // ===== 고장 =====
  {
    const bm=P.map(p=>WK.filter(x=>keyOfDate(x.wd)===p.key&&x.stage==='BM').length);
    const cbm=P.map(p=>WK.filter(x=>keyOfDate(x.wd)===p.key&&x.stage==='CBM').length);
    destroyMk('cFt');
    CHARTS.cFt=new Chart(document.getElementById('cFt'),{type:'bar',
      data:{labels,datasets:[
        {label:'BM',data:bm,backgroundColor:TH.status.bad,stack:'s',borderRadius:2},
        {label:'CBM',data:cbm,backgroundColor:TH.status.warn,stack:'s',borderRadius:2}]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:'bottom',labels:{color:TH.txt,font:{size:10},usePointStyle:true,pointStyle:'circle',boxWidth:6,padding:8}},
          tooltip:{callbacks:{footer:it=>'Σ '+it.reduce((a,i)=>a+i.parsed.y,0)}}},
        scales:baseScales(TH,true)}});
    // TOP3 표
    const f30=WK.filter(x=>x.wd>=d30&&isFault(x.stage));
    const byCause={}; let noCause=0;
    f30.forEach(x=>{ if(!x.cause){noCause++;return;} (byCause[x.cause]=byCause[x.cause]||[]).push(x); });
    const top=Object.entries(byCause).sort((a,b)=>b[1].length-a[1].length);
    const body=document.getElementById('top3Body');
    if(!top.length){ body.innerHTML='<tr><td colspan="5" class="empty">—</td></tr>'; document.getElementById('top3Etc').textContent=''; }
    else{
      body.innerHTML=top.slice(0,3).map(([c,arr],i)=>{
        const ph={}; arr.forEach(x=>{if(x.phenom)ph[x.phenom]=(ph[x.phenom]||0)+1;});
        const topPh=Object.entries(ph).sort((a,b)=>b[1]-a[1])[0];
        const latest=arr.slice().sort((a,b)=>b.wd-a.wd).find(x=>x.action);
        return '<tr><td><span class="rank r'+(i+1)+'">'+(i+1)+'</span></td><td>'+c+'</td><td class="num"><b>'+arr.length+'</b></td><td>'+(topPh?topPh[0]:'—')+'</td><td>'+(latest?latest.action:'—')+'</td></tr>';
      }).join('');
      const etcN=top.slice(3).reduce((a,e)=>a+e[1].length,0);
      document.getElementById('top3Etc').textContent=(etcN||noCause)?t('top_etc').replace('{n}',etcN).replace('{m}',noCause):'';
    }
  }

  // ===== 설비 =====
  {
    const on=INST.filter(r=>pd(r[CI.turnOn])).length;
    setTxt('bnIn',INST.length.toLocaleString());
    setTxt('bnOn',on.toLocaleString());
    setTxt('bnRate',INST.length?Math.round(on/INST.length*100)+'%':'—');
    const byCust={};
    INST.forEach(r=>{const c=String(r[CI.customer]||'').trim()||'—';
      byCust[c]=byCust[c]||{in:0,on:0}; byCust[c].in++; if(pd(r[CI.turnOn]))byCust[c].on++;});
    const topC=Object.entries(byCust).sort((a,b)=>b[1].in-a[1].in).slice(0,6);
    destroyMk('cInst');
    CHARTS.cInst=new Chart(document.getElementById('cInst'),{type:'bar',
      data:{labels:topC.map(e=>e[0]),datasets:[
        {label:t('inst_in'),data:topC.map(e=>e[1].in),backgroundColor:TH.pal[0]+'66',borderColor:TH.pal[0],borderWidth:1.5,borderRadius:3},
        {label:t('inst_on'),data:topC.map(e=>e[1].on),backgroundColor:TH.pal[1],borderRadius:3}]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:'bottom',labels:{color:TH.txt,font:{size:10},usePointStyle:true,pointStyle:'circle',boxWidth:6,padding:8}},
          tooltip:{callbacks:{label:c=>' '+c.dataset.label+' '+c.parsed.y.toLocaleString()}}},
        scales:baseScales(TH,false)}});
  }

  // ===== 인사이트 =====
  {
    const ins=[];
    if(scPlan>0){
      const p=Math.round(scDone/scPlan*100);
      ins.push({sev:p<70?'warn':'ok',text:t('ins_pm').replace('{p}','<b>'+p+'</b>')
        .replace('{a}',scPlan.toLocaleString()).replace('{b}',scDone.toLocaleString())});
    }
    const f30n=WK.filter(x=>x.wd>=d30&&isFault(x.stage)).length;
    const fPrev=WK.filter(x=>x.wd>=d60&&x.wd<d30&&isFault(x.stage)).length;
    const fd=GST.pctDelta(f30n,fPrev);
    if(f30n||fPrev)ins.push({sev:(fd!=null&&fd>=30)?'bad':(fd!=null&&fd<=-20)?'ok':'info',
      text:t('ins_ft').replace('{n}','<b>'+f30n+'</b>').replace('{p}',fd==null?'—':(fd>0?'+':'')+fd+'%')});
    if(act.length)ins.push({sev:'info',text:t('ins_hc').replace('{n}','<b>'+act.length+'</b>').replace('{a}',joinM).replace('{b}',quitM)});
    GST.insights((HR.length||WK.length)?ins:[]);
  }
}

applyLang(); loadData();
</script>
<script>
(function(){
  function isAuthed(){try{return sessionStorage.getItem('gst_auth')==='1';}catch(e){return false;}}
  window.checkPw=async function(){
    const v=document.getElementById('pwInput').value;
    if(await GST.checkPw(v)){
      try{sessionStorage.setItem('gst_auth','1');}catch(e){}
      document.getElementById('loginOverlay').classList.add('hidden');
    }else{
      document.getElementById('pwErr').textContent='비밀번호가 올바르지 않습니다 / Incorrect';
      document.getElementById('pwInput').value='';
    }
  };
  function init(){
    if(isAuthed()){document.getElementById('loginOverlay').classList.add('hidden');return;}
    const inp=document.getElementById('pwInput');
    inp.addEventListener('keydown',e=>{if(e.key==='Enter')window.checkPw();});
    setTimeout(()=>inp.focus(),100);
  }
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);
  else init();
})();
GST.initSync();
</script>
</body>
</html>
