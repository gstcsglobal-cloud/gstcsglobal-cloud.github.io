<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root{
  --bg-gradient: linear-gradient(-45deg, #0a1420, #13232d, #0f2027, #0c1a1f);
  --title-gradient: linear-gradient(90deg, #2dd4bf, #38bdf8, #a78bfa);
  --glass: rgba(255,255,255,0.05); --glass-border: rgba(255,255,255,0.12); --glass-hover: rgba(255,255,255,0.1);
  --txt-main:#e2e8f0; --txt-muted:#94a3b8;
  --accent-1:#2dd4bf; --accent-2:#38bdf8; --accent-3:#a78bfa; --accent-4:#fbbf24; --accent-5:#34d399;
  --card-shadow:0 8px 32px 0 rgba(0,0,0,0.37);
}
body.theme-burgundy{
  --bg-gradient: linear-gradient(-45deg, #1a0813, #2d0b1e, #1f0822, #140511);
  --title-gradient: linear-gradient(90deg, #fcd34d, #f472b6, #fb7185);
  --glass:rgba(255,255,255,0.04); --glass-border:rgba(255,240,245,0.12); --glass-hover:rgba(255,240,245,0.09);
  --txt-main:#fbeaf4; --txt-muted:#b49aa9;
  --accent-1:#fcd34d; --accent-2:#f472b6; --accent-3:#fb7185; --accent-4:#f472b6; --accent-5:#fb7185;
}
body.theme-light{
  --bg-gradient: linear-gradient(-45deg, #f1f5f9, #e2e8f0, #e8eef5, #f0f4f8);
  --title-gradient: linear-gradient(90deg, #0f172a, #2563eb, #7c3aed);
  --glass:rgba(255,255,255,0.75); --glass-border:rgba(15,23,42,0.08); --glass-hover:rgba(15,23,42,0.04);
  --txt-main:#0f172a; --txt-muted:#64748b;
  --accent-1:#2563eb; --accent-2:#0284c7; --accent-3:#7c3aed; --accent-4:#ea580c; --accent-5:#16a34a;
}
body{
  font-family:'Segoe UI','Malgun Gothic',sans-serif; color:var(--txt-main);
  background:var(--bg-gradient);
  background-size:400% 400%; animation:grad 18s ease infinite; min-height:100vh; padding:28px 32px;
}
@keyframes grad{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
.header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px}
.header h1{font-size:32px;font-weight:800;background:var(--title-gradient);
  -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-1px}
.header .sub{color:var(--txt-muted);font-size:13px;margin-top:4px}
.header-right{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.btn{background:linear-gradient(90deg,var(--accent-1),var(--accent-2));border:none;border-radius:30px;color:#fff;font-size:13px;font-weight:700;cursor:pointer;padding:9px 20px;transition:opacity .2s;text-decoration:none;display:inline-block}
.btn:hover{opacity:.85}
.btn-back{background:var(--glass);border:1px solid var(--glass-border);color:var(--txt-main)}
.lang-wrap{position:relative}
.lang-btn{background:var(--glass);border:1px solid var(--glass-border);color:var(--txt-main);padding:9px 14px;border-radius:30px;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px}
.lang-dropdown{position:absolute;top:calc(100% + 8px);right:0;background:#1a2430;border:1px solid var(--glass-border);border-radius:14px;padding:6px;z-index:100;min-width:130px;display:none}
.lang-dropdown.open{display:block}
.lang-item{padding:9px 14px;border-radius:10px;cursor:pointer;font-size:13px;font-weight:600}
.lang-item:hover{background:rgba(255,255,255,.08)}
.status{font-size:12px;color:var(--txt-muted);margin-bottom:14px;text-align:right}
.status.ok{color:var(--accent-2)} .status.err{color:#fb7185}

.rpt-toolbar{display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap}
.pt-btn{background:var(--glass);border:1px solid var(--glass-border);border-radius:20px;padding:7px 18px;color:var(--txt-muted);font-size:12px;font-weight:700;cursor:pointer}
.pt-btn.active{color:#fff;background:linear-gradient(90deg,var(--accent-1),var(--accent-2));border-color:transparent}
body.theme-light .pt-btn.active{color:#fff}
.pt-note{font-size:11px;color:var(--txt-muted);margin-left:4px}
.pt-sp{flex:1}

.kpis{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin-bottom:20px}
.kpi{background:var(--glass);border:1px solid var(--glass-border);border-radius:18px;padding:16px 18px;backdrop-filter:blur(14px)}
.kpi .val{font-size:27px;font-weight:800;line-height:1.1}
.kpi .cap{color:var(--txt-muted);font-size:11.5px;margin-top:6px;font-weight:600}
.kpi .kf{color:var(--txt-muted);font-size:10.5px;margin-top:3px}
.kpi .kd{font-size:11px;font-weight:700;margin-left:4px}

.sec-h{font-size:13px;font-weight:800;color:var(--txt-muted);letter-spacing:1.5px;text-transform:uppercase;margin:22px 0 10px 2px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px}
.grid2{display:grid;grid-template-columns:1.25fr 1fr;gap:16px;margin-bottom:16px}
.card{background:var(--glass);border:1px solid var(--glass-border);border-radius:18px;padding:18px;backdrop-filter:blur(14px)}
.card h3{font-size:13.5px;font-weight:700;margin-bottom:4px;color:var(--txt-main)}
.card .card-note{font-size:10.5px;color:var(--txt-muted);margin-bottom:10px}
.card .cw{position:relative;height:250px}
.bignums{display:flex;flex-direction:column;gap:14px;justify-content:center;height:250px}
.bn{display:flex;align-items:baseline;gap:10px}
.bn .n{font-size:30px;font-weight:800;min-width:110px;text-align:right}
.bn .l{font-size:12px;color:var(--txt-muted);font-weight:600}
.tablecard{background:var(--glass);border:1px solid var(--glass-border);border-radius:18px;padding:18px;backdrop-filter:blur(14px);margin-bottom:16px}
.tablecard h3{font-size:13.5px;font-weight:700;margin-bottom:10px}
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:left;padding:9px 11px;color:var(--txt-muted);font-size:10px;text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid var(--glass-border)}
td{padding:8px 11px;border-bottom:1px solid var(--glass-border)}
td.num{text-align:right;font-variant-numeric:tabular-nums}
.rank{display:inline-block;width:22px;height:22px;border-radius:50%;text-align:center;line-height:22px;font-weight:800;font-size:11px;background:var(--glass-hover)}
.rank.r1{background:rgba(230,103,103,.25);color:#e66767}
.rank.r2{background:rgba(250,178,25,.22);color:#fab219}
.empty{text-align:center;padding:24px;color:var(--txt-muted)}
@media(max-width:1250px){.kpis{grid-template-columns:repeat(3,1fr)}.grid3{grid-template-columns:1fr 1fr}.grid2{grid-template-columns:1fr}}
@media(max-width:800px){.kpis{grid-template-columns:repeat(2,1fr)}.grid3{grid-template-columns:1fr}}
@media print{
  body{padding:10px;background:#fff !important;animation:none}
  .header-right,.rpt-toolbar,.status{display:none !important}
  .card,.tablecard,.kpi{break-inside:avoid;border:1px solid #ddd}
  .cw{height:220px}
}

/* 로그인 가드 */
#loginOverlay{position:fixed;inset:0;z-index:99999;
  background:linear-gradient(-45deg,#0f0c29,#302b63,#24243e,#1a1a2e);
  background-size:400% 400%;animation:grad 18s ease infinite;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;font-family:'Segoe UI','Malgun Gothic',sans-serif}
#loginOverlay.hidden{display:none}
.login-logo{font-size:38px;font-weight:900;background:linear-gradient(90deg,#00cec9,#6c5ce7,#fd79a8);
  -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:6px;letter-spacing:-2px}
.login-box{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:24px;
  padding:36px 40px;backdrop-filter:blur(14px);text-align:center;min-width:300px}
.login-box .lock{font-size:40px;margin-bottom:14px}
.login-box .ltitle{font-size:16px;font-weight:700;margin-bottom:18px;color:#f5f6fa}
.login-box input{width:100%;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.18);
  border-radius:30px;padding:13px 20px;color:#f5f6fa;font-size:15px;outline:none;text-align:center}
.login-box input::placeholder{color:#a0a0c0}
.login-box button{width:100%;margin-top:14px;background:linear-gradient(90deg,#6c5ce7,#00cec9);
  border:none;border-radius:30px;padding:13px;color:#fff;font-size:15px;font-weight:700;cursor:pointer}
.login-err{color:#fd79a8;font-size:13px;margin-top:12px;min-height:18px;font-weight:600}
</style>
<link rel="stylesheet" href="https://gstcsglobal-cloud.github.io/assets/theme.css">
</head>
<body>

<div id="loginOverlay">
  <div class="login-logo">GST Dashboard</div>
  <div class="login-box">
    <div class="lock">🔒</div>
    <div class="ltitle">비밀번호를 입력하세요 / Enter password</div>
    <input type="password" id="pwInput" placeholder="비밀번호 / Password" autocomplete="off">
    <button onclick="checkPw()">로그인 / Login</button>
    <div class="login-err" id="pwErr"></div>
  </div>
</div>

<div class="header">
  <div>
    <h1 data-i="title">통합 운영 현황</h1>
    <div class="sub" data-i="sub">인력 · 교육 · 작업 · PM · 고장 주간/월간 요약</div>
  </div>
  <div class="header-right">
    <a href="https://gstcsglobal-cloud.github.io" class="btn btn-back" data-i="back">← 메인으로</a>
    <button class="btn" onclick="loadData()" data-i="refresh">새로고침</button>
    <div class="lang-wrap">
      <button class="lang-btn" onclick="toggleLang()"><span id="langLabel">KO</span> ▾</button>
      <div class="lang-dropdown" id="langMenu">
        <div class="lang-item" onclick="setLang('ko')">🇰🇷 한국어</div>
        <div class="lang-item" onclick="setLang('en')">🇺🇸 English</div>
        <div class="lang-item" onclick="setLang('zh')">🇨🇳 中文</div>
        <div class="lang-item" onclick="setLang('ja')">🇯🇵 日本語</div>
      </div>
    </div>
  </div>
</div>
<div class="status" id="status">데이터 불러오는 중...</div>

<div class="rpt-toolbar">
  <button class="pt-btn" id="ptW" onclick="setPeriod('w')" data-i="per_w">주별</button>
  <button class="pt-btn" id="ptM" onclick="setPeriod('m')" data-i="per_m">월별</button>
  <span class="pt-note" data-i="per_note">최근 12개 구간</span>
  <span class="pt-sp"></span>
  <button class="pt-btn" onclick="window.print()" data-i="print">🖨 인쇄</button>
</div>

<div class="kpis">
  <div class="kpi"><div class="val" id="kp1">—</div><div class="cap" data-i="kp1">재직 인원</div><div class="kf" id="kf1"></div></div>
  <div class="kpi"><div class="val" id="kp2">—</div><div class="cap" data-i="kp2">이번 달 입사 · 퇴사</div><div class="kf" id="kf2"></div></div>
  <div class="kpi"><div class="val" id="kp3">—</div><div class="cap" data-i="kp3">Basic 교육 완료율</div><div class="kf" id="kf3"></div></div>
  <div class="kpi"><div class="val" id="kp4">—<span class="kd" id="kd4"></span></div><div class="cap" data-i="kp4">작업 건수 · 최근 30일</div><div class="kf" id="kf4"></div></div>
  <div class="kpi"><div class="val" id="kp5">—</div><div class="cap" data-i="kp5">작업 공수(h) · 최근 30일</div><div class="kf" id="kf5"></div></div>
  <div class="kpi"><div class="val" id="kp6">—</div><div class="cap" data-i="kp6">PM 진행율 · 올해</div><div class="kf" id="kf6"></div></div>
</div>

<div class="sec-h" data-i="sec1">인력 · 교육</div>
<div class="grid3">
  <div class="card">
    <h3 data-i="ch_hc">인원 추이 (경력구간)</h3>
    <div class="card-note" data-i="note_hc">각 구간 말 기준 재직 인원 · 입사일/퇴사일 반영</div>
    <div class="cw"><canvas id="cHc"></canvas></div>
  </div>
  <div class="card">
    <h3 data-i="ch_io">입사 · 퇴사</h3>
    <div class="card-note" data-i="note_io">구간별 입사/퇴사 인원</div>
    <div class="cw"><canvas id="cIo"></canvas></div>
  </div>
  <div class="card">
    <h3 data-i="ch_edu">교육 완료율 추이</h3>
    <div class="card-note" data-i="note_edu">이수일 기준 누적 완료 / 해당 시점 재직 인원</div>
    <div class="cw"><canvas id="cEdu"></canvas></div>
  </div>
</div>

<div class="sec-h" data-i="sec2">작업 실행력</div>
<div class="grid3">
  <div class="card">
    <h3 data-i="ch_jobs">작업 건수</h3>
    <div class="card-note" data-i="note_jobs">전체 작업 실적 · 최대/최신값 라벨</div>
    <div class="cw"><canvas id="cJobs"></canvas></div>
  </div>
  <div class="card">
    <h3 data-i="ch_man">작업 공수 (h)</h3>
    <div class="card-note" data-i="note_man">PM · 서비스 · 설치 구분 (이상치 제외)</div>
    <div class="cw"><canvas id="cMan"></canvas></div>
  </div>
  <div class="card">
    <h3 data-i="ch_pc">인당 작업 건수</h3>
    <div class="card-note" data-i="note_pc">구간 내 실제 투입 인원 기준</div>
    <div class="cw"><canvas id="cPc"></canvas></div>
  </div>
</div>

<div class="sec-h" data-i="sec3">PM · 고장</div>
<div class="grid2">
  <div class="card">
    <h3 data-i="ch_sc">PM 계획 대비 완료 (올해 누적)</h3>
    <div class="card-note" data-i="note_sc">계획 = 설비별 주기 기반 도래 건수 · 진행율은 툴팁</div>
    <div class="cw"><canvas id="cSc"></canvas></div>
  </div>
  <div class="card">
    <h3 data-i="ch_ft">고장 건수 (BM · CBM)</h3>
    <div class="card-note" data-i="note_ft">합계는 툴팁</div>
    <div class="cw"><canvas id="cFt"></canvas></div>
  </div>
</div>
<div class="tablecard">
  <h3 data-i="tbl_top">고장 원인 TOP 3 (최근 30일)</h3>
  <table>
    <thead><tr><th>#</th><th data-i="th_cause">원인</th><th data-i="th_cnt">건수</th><th data-i="th_ph">주요 현상</th><th data-i="th_act">최근 조치</th></tr></thead>
    <tbody id="top3Body"><tr><td colspan="5" class="empty">—</td></tr></tbody>
  </table>
  <div class="card-note" id="top3Etc" style="margin-top:8px"></div>
</div>

<div class="sec-h" data-i="sec4">설비</div>
<div class="grid2">
  <div class="card">
    <h3 data-i="ch_inst">고객사별 반입 · 가동</h3>
    <div class="card-note" data-i="note_inst">설치 시트 기준 · 가동 = Turn-On 완료</div>
    <div class="cw"><canvas id="cInst"></canvas></div>
  </div>
  <div class="card">
    <h3 data-i="ch_sum">설비 요약</h3>
    <div class="card-note">&nbsp;</div>
    <div class="bignums">
      <div class="bn"><span class="n" id="bnIn">—</span><span class="l" data-i="bn_in">전체 반입 설비</span></div>
      <div class="bn"><span class="n" id="bnOn">—</span><span class="l" data-i="bn_on">가동 설비 (Turn-On)</span></div>
      <div class="bn"><span class="n" id="bnRate">—</span><span class="l" data-i="bn_rate">가동율</span></div>
    </div>
  </div>
</div>

